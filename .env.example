# API 配置
API_KEY=your_api_key_here
BASE_URL=https://api.minimaxi.com/anthropic  # 或其他 API 地址
API_TYPE=anthropic  # openai 或 anthropic

# 多模型配置（自定义模型名称）
SUPERVISOR_MODEL=claude-sonnet-4-6
WRITER_MODEL=claude-sonnet-4-6
SPECIALIST_MODEL=claude-haiku-4-5

# API 服务器配置
API_HOST=127.0.0.1
API_PORT=7999  # 统一服务端口（Gradio UI + FastAPI）
